{
  "name": "marken",
  "private": true,
  "version": "0.1.0",
  "description": "A lightweight, self-hosted Markdown viewer.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build:client": "vite build",
    "build:static": "node scripts/copy-static.mjs",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/server.js --packages=bundle --loader:.tsx=tsx --loader:.ts=ts --banner:js=\"import { createRequire as __mkRequire } from 'module'; const require = __mkRequire(import.meta.url);\"",
    "build": "rm -rf dist && npm run build:client && npm run build:static && npm run build:server",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "highlight.js": "^11.11.1",
    "hono": "^4.6.14",
    "katex": "^0.16.15",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.4.1",
    "mime": "^4.0.6",
    "minisearch": "^7.1.1",
    "preact": "^10.25.4",
    "preact-render-to-string": "^6.5.13"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.2",
    "happy-dom": "^20.9.0",
    "puppeteer-core": "^24.43.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
